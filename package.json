{
  "name": "trim-indent",
  "displayName": "Trim Indent",
  "description": "Remove common leading whitespace from selected text",
  "main": "./dist/extension.js",
  "version": "1.2.1",
  "publisher": "prberg",
  "repository": {
    "type": "git",
    "url": "https://github.com/PaulRBerg/trim-indent"
  },
  "license": "MIT",
  "keywords": [
    "dedent",
    "indent",
    "trim",
    "whitespace",
    "vscode"
  ],
  "activationEvents": [
    "onCommand:extension.trimIndent",
    "onCommand:extension.copyTrimmed"
  ],
  "categories": [
    "Formatters"
  ],
  "contributes": {
    "commands": [
      {
        "command": "extension.trimIndent",
        "title": "Trim Indent"
      },
      {
        "command": "extension.copyTrimmed",
        "title": "Trim Indent and Copy"
      }
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@sablier/devkit": "^1.9.1",
    "@types/node": "^25.0.3",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.2",
    "typescript": "^5.9.3",
    "ultracite": "^6.5.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "vscode": "^1.85.0"
  }
}
